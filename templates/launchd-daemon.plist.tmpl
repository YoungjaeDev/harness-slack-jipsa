<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
Agent Bootstrap — Slack daemon launchd
파일: ~/Library/LaunchAgents/com.{USERNAME}.slack-jipsa.plist
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.{USERNAME}.slack-jipsa</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>{HOME}/.claude/scripts/slack-jipsa/run.sh</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>{HOME}/.claude/scripts/slack-jipsa/logs/launchd.out</string>

    <key>StandardErrorPath</key>
    <string>{HOME}/.claude/scripts/slack-jipsa/logs/launchd.err</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>
</dict>
</plist>
