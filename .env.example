# Agent Bootstrap — 환경변수 템플릿
# 실제 파일은 ~/.claude/secrets/slack-jipsa.env (chmod 600)
# 이 .env.example 은 GitHub에 올라가도 안전합니다. 실제 토큰은 절대 커밋 금지.

# ─────────────────────────────────────────────────────
# 슬랙 (모듈 1·3 필수)
# ─────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_CHANNEL=C0XXXXXXXXX

# 본인 슬랙 user ID — 봇이 응답할 대상
USER_SLACK_ID=U0XXXXXXXXX

# 봇 user ID — 자기 자신 메시지 무한루프 방지 (auth.test로 얻음)
BOT_USER_ID=U0XXXXXXXXX

# (선택) 봇이 보낼 다른 채널 — 두 봇 토론 모드 등. 안 쓰면 공란
SLACK_CHANNEL_DIALOG=

# 봇 표시 이름 (시스템 프롬프트·로그에 사용)
SLACK_BOT_NAME=슬랙 비서

# 사용자 호칭 (시스템 프롬프트에 사용. 예: 철수, 영희, John)
USER_NAME=사용자

# Stop hook → 슬랙 요약 webhook URL (선택, Incoming Webhook)
# Bot Token 만 있어도 chat.postMessage 로 보낼 수 있지만, 분리된 webhook 사용 시
SLACK_SESSION_WEBHOOK=

# ─────────────────────────────────────────────────────
# 노션 적재 (모듈 4 선택)
# ─────────────────────────────────────────────────────
# notion.so/my-integrations 에서 만든 Internal Integration Secret
NOTION_API_TOKEN=

# Claude Code 턴 로그 DB ID (32자 hex, 사용자 자기 DB)
NOTION_SESSION_DB=

# (옵션) 일일 통합 DB ID — "일별 hub" 패턴. 없어도 됨
NOTION_DAILY_DB=
